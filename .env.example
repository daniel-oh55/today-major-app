# Baseball Data Provider 선택
# 가능한 값: dummy | balldontlie_skeleton | mysportsfeeds_skeleton | sportsdataio_skeleton | sportradar_skeleton | rolling_insights_skeleton
# skeleton provider는 runtime에 선택되면 자동으로 dummy로 fallback됩니다.
# 실제 API 연결 전 반드시 계약 및 약관을 확인하세요.
BASEBALL_DATA_PROVIDER=dummy

# Baseball API Key (서버 환경변수에만 보관, 프론트엔드에 절대 노출 금지)
BASEBALL_API_KEY=

# Baseball API Base URL (실제 API 연결 시 설정)
BASEBALL_API_BASE_URL=

# API 응답 타임아웃 (ms). 설정하지 않으면 provider 기본값 사용.
# BASEBALL_API_TIMEOUT_MS=5000

# Provider 런타임 모드 (개발용 안전장치)
# dummy_only: 어떤 env 설정이든 dummy만 사용
# safe_dummy_fallback: 기본값 — 미지원 provider는 dummy로 fallback
# BASEBALL_PROVIDER_RUNTIME_MODE=safe_dummy_fallback

# 사이트 URL (production에서 설정)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── 광고 설정 ──
# 광고 SDK 연동 시 아래 값을 설정합니다.
# 현재는 placeholder provider만 동작합니다.
# 실제 광고 ID/API Key는 이 파일에 절대 작성하지 마세요.
# NEXT_PUBLIC_AD_PROVIDER=placeholder   # placeholder | adsense | ad-manager | admob-webview
# AD_PUBLISHER_ID=                      # 광고 publisher ID (서버 전용)
# AD_APP_ID=                            # 광고 앱 ID (서버 전용)
